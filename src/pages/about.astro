---
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'About',
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="About"
    image={`<img class="mx-auto rounded-md w-full" src="https://images.unsplash.com/photo-1517048676732-d65bc937f952?auto=format&fit=crop&w=2070&q=80" alt="Marketing consultant facilitating a strategy workshop" loading="eager" />`}
  >
    <Fragment slot="title">
      Senior marketing judgement for teams that need <span class="text-accent dark:text-white">clearer choices</span>
    </Fragment>

    <Fragment slot="subtitle">
      BrightPath Marketing is an independent consultancy for B2B service firms that need sharper positioning, better
      campaign focus, and a calmer way to decide what marketing should do next.
    </Fragment>
  </Hero>

  <Stats
    title="How the work is shaped"
    stats={[
      { title: 'Discovery-led', amount: '1st' },
      { title: 'Strategy horizon', amount: '90 days' },
      { title: 'Primary focus', amount: 'B2B' },
      { title: 'Engagement style', amount: 'Hands-on' },
    ]}
  />

  <Features3
    title="Consulting principles"
    subtitle="The aim is to reduce ambiguity and help the team make better marketing decisions with less wasted motion."
    columns={3}
    isBeforeContent={true}
    items={[
      {
        title: 'Specific beats clever',
        description:
          'Good messaging says exactly who the work is for, what problem it solves, and why the approach is credible.',
        icon: 'tabler:message-2-check',
      },
      {
        title: 'Strategy should constrain',
        description:
          'A useful strategy makes some choices obvious and makes other ideas easier to decline.',
        icon: 'tabler:arrows-minimize',
      },
      {
        title: 'Execution needs rhythm',
        description:
          'Campaigns improve when the team has a cadence for planning, shipping, reviewing, and adjusting.',
        icon: 'tabler:refresh',
      },
    ]}
  />

  <Features3
    columns={3}
    isAfterContent={true}
    items={[
      {
        title: 'Buyer reality first',
        description:
          'Recommendations are grounded in sales context, buyer questions, objections, proof needs, and the cost of inaction.',
        icon: 'tabler:user-search',
      },
      {
        title: 'No vanity metrics',
        description:
          'Attention goes to signals that help the business make decisions, not numbers that look good in isolation.',
        icon: 'tabler:chart-dots',
      },
      {
        title: 'Useful handoff',
        description:
          'Outputs are written so founders, marketers, sellers, agencies, and freelancers can use them immediately.',
        icon: 'tabler:clipboard-check',
      },
    ]}
    image={`<img class="w-full h-80 object-cover rounded-xl mx-auto bg-gray-500 shadow-lg" src="https://images.unsplash.com/photo-1556761175-4b46a572b786?auto=format&fit=crop&w=1740&q=80" alt="Small team aligning around a marketing plan" loading="lazy" />`}
  />

  <Steps2
    title="What it feels like to work together"
    subtitle="The process is collaborative, direct, and designed around decisions your business actually has to make."
    items={[
      {
        title: 'Candid diagnosis',
        description:
          'We look closely at where the offer, market, message, website, campaigns, or handoff are creating friction.',
      },
      {
        title: 'Practical strategy',
        description:
          'The recommendations focus on what your team can execute, not an idealized marketing department you do not have.',
      },
      {
        title: 'Clear next actions',
        description:
          'Every engagement ends with owners, priorities, timelines, and a way to review whether the work is improving.',
      },
    ]}
  />

  <Steps2
    title="Common reasons teams reach out"
    subtitle="The best starting point is usually a problem that has become too expensive or distracting to keep guessing at."
    isReversed={true}
    callToAction={{
      text: 'Talk through your situation',
      href: '/contact',
    }}
    items={[
      {
        title: 'The website no longer matches the business',
        description:
          'Services have evolved, the best clients have changed, or the homepage is trying to speak to too many people.',
        icon: 'tabler:world-question',
      },
      {
        title: 'Marketing is busy but unclear',
        description:
          'Content, email, social, events, and ads are happening, but the team is not sure what is creating qualified demand.',
        icon: 'tabler:activity',
      },
      {
        title: 'Sales conversations start too cold',
        description:
          'Prospects arrive without enough context, do not understand the value, or compare the service too narrowly on price.',
        icon: 'tabler:messages',
      },
    ]}
  />

  <Features2
    title="Best fit"
    tagline="Who this helps"
    columns={4}
    items={[
      {
        title: 'Consultancies',
        description: 'Expert teams selling strategy, operations, technology, finance, or specialized advisory services.',
      },
      {
        title: 'Agencies',
        description: 'Service businesses that need sharper positioning, packages, or lead-generation strategy.',
      },
      {
        title: 'B2B founders',
        description: 'Founder-led companies that need senior marketing direction before hiring or scaling spend.',
      },
      {
        title: 'Fractional teams',
        description: 'Lean teams coordinating internal contributors, agencies, freelancers, or sales partners.',
      },
    ]}
  />

  <Features2
    title="Have a specific question?"
    tagline="Contact"
    columns={2}
    items={[
      {
        title: 'Book a fit call',
        description:
          'Use the contact form to share the current challenge and the decision you need to make next.',
        icon: 'tabler:calendar-check',
      },
      {
        title: 'Send context first',
        description:
          'If useful, include your website, target customer, current marketing channels, and what is not working.',
        icon: 'tabler:mail-forward',
      },
    ]}
  />
</Layout>
