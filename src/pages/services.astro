---
import CallToAction from '~/components/widgets/CallToAction.astro';
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Services',
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="Services"
    title="Marketing consulting for sharper positioning and stronger demand"
    subtitle="Choose the support that matches your current constraint: clarify the offer, improve the website journey, plan campaigns, or build a repeatable marketing operating rhythm."
    actions={[{ variant: 'primary', text: 'Discuss your priorities', href: '/contact' }]}
    image={`<img class="mx-auto rounded-md w-full" src="https://images.unsplash.com/photo-1553877522-43269d4ea984?auto=format&fit=crop&w=1740&q=80" alt="Marketing consultant working through strategy with a client team" loading="eager" />`}
  />

  <Features2
    title="Core consulting areas"
    subtitle="Engagements can be scoped as a focused sprint or combined into an advisory program."
    columns={3}
    items={[
      {
        title: 'Positioning sprint',
        description:
          'Clarify your ideal customer, category, service offer, promise, proof points, and objections so buyers understand you faster.',
        icon: 'tabler:target-arrow',
      },
      {
        title: 'Website conversion audit',
        description:
          'Review homepage, service pages, lead magnets, proof, forms, and calls to action with prioritized recommendations.',
        icon: 'tabler:world-search',
      },
      {
        title: 'Campaign strategy',
        description:
          'Build campaign briefs for launches, lead generation, nurture, events, search, LinkedIn, or email programs.',
        icon: 'tabler:speakerphone',
      },
      {
        title: 'Content and thought leadership',
        description:
          'Turn expertise into content pillars, article briefs, newsletter themes, case stories, and sales enablement assets.',
        icon: 'tabler:writing',
      },
      {
        title: 'Marketing operations',
        description:
          'Simplify reporting, lead source tracking, campaign planning, weekly priorities, and decision routines.',
        icon: 'tabler:chart-infographic',
      },
      {
        title: 'Fractional marketing advisory',
        description:
          'Ongoing strategy support for founders and small teams that need senior marketing judgement without a full-time hire.',
        icon: 'tabler:briefcase',
      },
    ]}
  />

  <Content
    isReversed
    items={[
      {
        title: 'Messaging that sales can use',
        description:
          'Value propositions, service descriptions, proof points, objection responses, and buyer language built for real conversations.',
        icon: 'tabler:message-2',
      },
      {
        title: 'Campaigns that connect',
        description:
          'Channel plans, content themes, conversion paths, and follow-up sequences designed around the buying journey.',
        icon: 'tabler:git-merge',
      },
      {
        title: 'Measurement that guides decisions',
        description:
          'A simple scorecard that separates useful leading indicators from noise and keeps weekly decisions grounded.',
        icon: 'tabler:chart-arcs',
      },
    ]}
    image={`<img class="mx-auto w-full rounded-lg bg-gray-500 shadow-lg" src="https://images.unsplash.com/photo-1556761175-b413da4baf72?auto=format&fit=crop&w=870&q=80" alt="Client team reviewing marketing priorities" loading="lazy" />`}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2">Useful outputs, not bloated decks</h3>
      Deliverables are designed to be used by founders, marketers, sellers, agencies, and freelancers.
    </Fragment>
  </Content>

  <Content
    isAfterContent
    items={[
      {
        title: 'For expert-led businesses',
        description:
          'Best fit for firms selling complex services where trust, clarity, authority, and timing matter more than quick discounts.',
        icon: 'tabler:user-star',
      },
      {
        title: 'For lean marketing teams',
        description:
          'Helpful when the team has execution capacity but needs sharper priorities and senior direction.',
        icon: 'tabler:users-group',
      },
      {
        title: 'For stalled growth',
        description:
          'Useful when traffic, content, or campaigns exist, but qualified pipeline is inconsistent or hard to explain.',
        icon: 'tabler:trending-up',
      },
    ]}
    image={`<img class="mx-auto w-full rounded-lg bg-gray-500 shadow-lg" src="https://images.unsplash.com/photo-1543269865-cbf427effbad?auto=format&fit=crop&w=774&q=80" alt="Workshop discussion with a small business team" loading="lazy" />`}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2">Where the work fits</h3>
      The consulting is practical enough for small teams and strategic enough to guide bigger decisions.
    </Fragment>
  </Content>

  <Testimonials
    title="What clients value"
    testimonials={[
      {
        testimonial: `The biggest shift was clarity. We stopped describing everything we could do and started leading with the problems our best clients actually cared about.`,
        name: 'Maya Collins',
        job: 'Founder, operations consultancy',
        image: {
          src: 'https://images.unsplash.com/photo-1580489944761-15a19d654956?auto=format&fit=crop&w=930&q=80',
          alt: 'Maya Collins portrait',
        },
      },
      {
        testimonial: `The campaign plan gave our small team a real operating rhythm. We knew what to publish, where to send people, and how to judge progress.`,
        name: 'Daniel Reeves',
        job: 'Managing partner, B2B agency',
        image: {
          src: 'https://images.unsplash.com/photo-1500648767791-00dcc994a43e?auto=format&fit=crop&w=774&q=80',
          alt: 'Daniel Reeves portrait',
        },
      },
      {
        testimonial: `Our website review was direct and useful. The recommendations helped us make the service pages more specific and easier to act on.`,
        name: 'Leah Martin',
        job: 'Principal consultant',
        image: {
          src: 'https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?auto=format&fit=crop&w=824&q=80',
          alt: 'Leah Martin portrait',
        },
      },
    ]}
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Plan your engagement',
        href: '/contact',
      },
    ]}
    title="Need help choosing the right starting point?"
    subtitle="Share the growth problem, current marketing activity, and what has been hard to fix."
  />
</Layout>
