---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'BrightPath Marketing - Strategy and growth consulting for B2B service firms',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <Hero
    id="home-hero"
    actions={[
      {
        variant: 'primary',
        text: 'Book a strategy call',
        href: '/contact',
        icon: 'tabler:calendar-check',
      },
      { text: 'View services', href: '#services' },
    ]}
    bg={`<div class="bp-hero-signal-bg" aria-hidden="true">
      <div class="bp-signal-visual" role="presentation">
        <span class="bp-signal-grid"></span>
        <span class="bp-signal-core"></span>
        <span class="bp-signal-line bp-signal-line-a"></span>
        <span class="bp-signal-line bp-signal-line-b"></span>
        <span class="bp-signal-line bp-signal-line-c"></span>
        <span class="bp-signal-node bp-signal-node-a"></span>
        <span class="bp-signal-node bp-signal-node-b"></span>
        <span class="bp-signal-node bp-signal-node-c"></span>
        <span class="bp-signal-label">MARKET SIGNAL / DEMAND SYSTEM</span>
      </div>
    </div>`}
  >
    <Fragment slot="title">
      Marketing strategy that turns expertise into <span class="text-accent dark:text-white">qualified demand</span>
    </Fragment>

    <Fragment slot="subtitle">
      BrightPath Marketing helps consultants, agencies, and B2B service firms clarify their offer, sharpen their
      messaging, and build practical campaigns that create better conversations with the right buyers.
    </Fragment>
  </Hero>

  <Note
    title="Built for owner-led teams:"
    description="Clear positioning, useful content, better conversion paths, and a realistic plan your team can actually run."
  />

  <Features
    id="services"
    tagline="Consulting services"
    title="Fix the growth bottleneck, not just the symptom"
    subtitle="Each engagement starts with the commercial goal, then works backward into positioning, channels, content, and conversion."
    items={[
      {
        title: 'Positioning and messaging',
        description:
          'Translate your expertise into a sharper market position, clearer service offers, and language buyers understand quickly.',
        icon: 'tabler:target-arrow',
      },
      {
        title: 'Go-to-market planning',
        description:
          'Define the right audience, channel mix, campaign priorities, budget assumptions, and operating cadence before spend scales.',
        icon: 'tabler:route',
      },
      {
        title: 'Website conversion review',
        description:
          'Audit key pages, calls to action, proof points, and buyer flow so more qualified visitors know what to do next.',
        icon: 'tabler:cursor-text',
      },
      {
        title: 'Content strategy',
        description:
          'Create an editorial system that answers real buyer questions and supports sales conversations instead of chasing empty volume.',
        icon: 'tabler:article',
      },
      {
        title: 'Lead generation campaigns',
        description:
          'Plan focused campaigns for LinkedIn, email, search, partner channels, or events with clean handoff into sales follow-up.',
        icon: 'tabler:speakerphone',
      },
      {
        title: 'Marketing operations',
        description:
          'Simplify tracking, campaign reporting, and weekly decision-making so the team can see what is working and what needs attention.',
        icon: 'tabler:chart-dots-3',
      },
    ]}
  />

  <Content
    id="approach"
    isReversed
    tagline="Approach"
    title="Strategy first, execution close behind"
    items={[
      {
        title: 'Diagnose the real constraint',
        description:
          'Review your current funnel, sales cycle, audience, offer, analytics, and content before prescribing channels.',
      },
      {
        title: 'Prioritize the moves that matter',
        description:
          'Choose a small set of high-leverage improvements instead of spreading budget and attention across every tactic.',
      },
      {
        title: 'Leave with an operating plan',
        description:
          'Turn the strategy into owners, timelines, messages, campaign briefs, measurement, and next-best actions.',
      },
    ]}
    image={`<img class="mx-auto w-full rounded-lg bg-gray-500 shadow-lg" src="https://images.unsplash.com/photo-1552664730-d307ca884978?auto=format&fit=crop&w=1740&q=80" alt="Consulting workshop with strategy notes on a whiteboard" loading="lazy" />`}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">No tactic theater</h3>
      Campaigns only work when the offer, message, audience, proof, and follow-up are aligned.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-primary/10 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <Steps
    id="process"
    title="A practical consulting process"
    items={[
      {
        title: 'Step 1: <span class="font-medium">Audit</span>',
        description:
          'Map the current customer journey, review performance signals, interview stakeholders, and identify where qualified demand is leaking.',
        icon: 'tabler:search',
      },
      {
        title: 'Step 2: <span class="font-medium">Position</span>',
        description:
          'Clarify the ideal buyer, core problem, commercial offer, value proposition, proof points, and objection handling.',
        icon: 'tabler:message-2-star',
      },
      {
        title: 'Step 3: <span class="font-medium">Plan</span>',
        description:
          'Build a realistic campaign roadmap with content themes, channel roles, conversion paths, owners, and measurement.',
        icon: 'tabler:calendar-stats',
      },
      {
        title: 'Step 4: <span class="font-medium">Improve</span>',
        description:
          'Review results, tighten weak points, and turn learning into the next round of decisions.',
        icon: 'tabler:chart-line',
      },
    ]}
    image={`<img class="object-cover object-top w-full rounded-md shadow-lg md:h-full" src="https://images.unsplash.com/photo-1542744173-8e7e53415bb0?auto=format&fit=crop&w=987&q=80" alt="Marketing planning session with charts and notes" loading="lazy" />`}
  />

  <Features2
    title="What improves first"
    subtitle="The first wins usually come from clearer choices, sharper copy, and fewer disconnected activities."
    tagline="Outcomes"
    items={[
      {
        title: 'A sharper service narrative',
        description: 'Buyers can tell who you help, what problem you solve, and why your approach is different.',
        icon: 'flat-color-icons:voice-presentation',
      },
      {
        title: 'Better-fit inquiries',
        description: 'Landing pages and calls to action filter interest toward conversations your team wants to have.',
        icon: 'flat-color-icons:business-contact',
      },
      {
        title: 'Campaigns with purpose',
        description: 'Every channel has a job, a message, a conversion path, and a simple measure of success.',
        icon: 'flat-color-icons:advertising',
      },
      {
        title: 'Sales-ready content',
        description: 'Insights, case stories, and explainers help prospects understand the cost of inaction.',
        icon: 'flat-color-icons:document',
      },
      {
        title: 'Cleaner reporting',
        description: 'Track leading indicators and sales impact without building a dashboard no one uses.',
        icon: 'flat-color-icons:statistics',
      },
      {
        title: 'A calmer marketing cadence',
        description: 'Weekly priorities become easier because the team knows what matters and what can wait.',
        icon: 'flat-color-icons:approval',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-primary/10 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <Stats
    stats={[
      { title: 'Strategy sprints', amount: '90-day' },
      { title: 'Core offers clarified', amount: '3-5' },
      { title: 'Decision cadence', amount: 'Weekly' },
      { title: 'Primary owner', amount: '1' },
    ]}
  />

  <FAQs
    title="Frequently asked questions"
    subtitle="Quick answers for teams considering a marketing strategy engagement."
    tagline="FAQs"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'Who is this consulting best for?',
        description:
          'B2B service businesses, consultants, agencies, and expert-led firms that have strong expertise but need clearer positioning, more qualified inquiries, or a more disciplined marketing plan.',
      },
      {
        title: 'Do you execute campaigns or only advise?',
        description:
          'Engagements can include campaign planning, copy direction, content briefs, conversion reviews, and implementation support. The goal is to make execution easier for your team or partners.',
      },
      {
        title: 'How soon can we see useful output?',
        description:
          'Most strategy sprints produce clear messaging, priority recommendations, and a practical 90-day plan within the first few weeks.',
      },
      {
        title: 'Can you work with our existing agency or freelancer?',
        description:
          'Yes. The work is designed to improve focus and handoff so internal teams, agencies, and freelancers can execute from a clearer brief.',
      },
      {
        title: 'What do we need before starting?',
        description:
          'Access to current website data, sales context, recent campaigns, customer insights, and a small stakeholder group that can make decisions.',
      },
      {
        title: 'Is this right if we are not ready to spend on ads?',
        description:
          'Yes. Positioning, messaging, website conversion, and sales-support content often need to be fixed before paid campaigns can perform well.',
      },
    ]}
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Book a strategy call',
        href: '/contact',
        icon: 'tabler:calendar-check',
      },
    ]}
  >
    <Fragment slot="title">Ready to make marketing easier to buy?</Fragment>

    <Fragment slot="subtitle">
      Bring the current challenge. Leave the first call with a clearer view of what to fix next.
    </Fragment>
  </CallToAction>
</Layout>
