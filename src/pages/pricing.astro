---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Prices from '~/components/widgets/Pricing.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Steps from '~/components/widgets/Steps.astro';
import Features3 from '~/components/widgets/Features3.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Pricing',
};
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Pricing"
    title="Focused consulting packages"
    subtitle="Simple engagement options for teams that need strategic clarity before adding more tactics."
  />

  <Prices
    title="Engagement options"
    subtitle="Final scope is confirmed after a short fit call."
    prices={[
      {
        title: 'Audit',
        subtitle: 'For teams that need the fastest diagnosis',
        price: 2500,
        period: 'one-time',
        items: [
          {
            description: 'Website and funnel review',
          },
          {
            description: 'Positioning and offer notes',
          },
          {
            description: 'Campaign and content observations',
          },
          {
            description: 'Prioritized action memo',
          },
        ],
        callToAction: {
          text: 'Start with an audit',
          href: '/contact',
        },
      },
      {
        title: 'Sprint',
        subtitle: 'For a clear 90-day marketing plan',
        price: 6500,
        period: 'project',
        items: [
          {
            description: 'Discovery and stakeholder interviews',
          },
          {
            description: 'Messaging and offer framework',
          },
          {
            description: 'Campaign roadmap and channel roles',
          },
          {
            description: 'Measurement scorecard',
          },
          {
            description: 'Implementation handoff session',
          },
        ],
        callToAction: {
          text: 'Plan a sprint',
          href: '/contact',
        },
        hasRibbon: true,
        ribbonTitle: 'popular',
      },
      {
        title: 'Advisory',
        subtitle: 'For ongoing senior marketing direction',
        price: 4500,
        period: 'per month',
        items: [
          {
            description: 'Monthly strategy priorities',
          },
          {
            description: 'Weekly decision support',
          },
          {
            description: 'Campaign and content reviews',
          },
          {
            description: 'Reporting and optimization cadence',
          },
        ],
        callToAction: {
          text: 'Discuss advisory',
          href: '/contact',
        },
      },
    ]}
  />

  <Features3
    title="What every engagement includes"
    subtitle="The work is structured to create practical decisions, clean handoff, and visible momentum."
    columns={2}
    items={[
      {
        title: 'Senior strategy time',
        description: 'Direct access to a consultant who can connect positioning, channels, content, and sales realities.',
        icon: 'tabler:user-star',
      },
      {
        title: 'Clear deliverables',
        description: 'No vague recommendations. You receive usable frameworks, briefs, scorecards, and priority lists.',
        icon: 'tabler:list-check',
      },
      {
        title: 'Stakeholder alignment',
        description: 'Structured working sessions help founders, sales, and marketing agree on what matters most.',
        icon: 'tabler:users',
      },
      {
        title: 'Implementation guidance',
        description: 'Recommendations are shaped so your team, agency, or freelancer can turn them into work.',
        icon: 'tabler:tools',
      },
      {
        title: 'Measurement plan',
        description: 'Define practical leading indicators and commercial outcomes before campaigns are judged.',
        icon: 'tabler:chart-bar',
      },
      {
        title: 'Plain-language communication',
        description: 'Expect direct writing, clear tradeoffs, and advice that respects your time and budget.',
        icon: 'tabler:message-circle',
      },
    ]}
    classes={{ container: 'max-w-5xl' }}
  />

  <Steps
    title="How booking works"
    tagline="Process"
    isReversed={true}
    items={[
      {
        title: 'Send context',
        icon: 'tabler:number-1',
      },
      {
        title: 'Join a fit call',
        icon: 'tabler:number-2',
      },
      {
        title: 'Confirm scope',
        icon: 'tabler:number-3',
      },
      {
        title: 'Start discovery',
        icon: 'tabler:number-4',
      },
      {
        title: 'Review recommendations',
        icon: 'tabler:number-5',
      },
      {
        title: 'Move into execution',
        icon: 'tabler:number-6',
      },
    ]}
    image={`<img class="object-cover object-top w-full rounded-md shadow-lg md:h-full" src="https://images.unsplash.com/photo-1557804506-669a67965ba0?auto=format&fit=crop&w=987&q=80" alt="Consulting team planning next steps" loading="lazy" />`}
  />

  <FAQs
    title="Pricing FAQs"
    subtitle="Common questions about scope, billing, and fit."
    columns={1}
    items={[
      {
        title: 'Can engagements be customized?',
        description:
          'Yes. The packages are starting points. Scope can be adjusted based on business size, urgency, stakeholder complexity, and implementation support needed.',
      },
      {
        title: 'Do you require a long-term contract?',
        description:
          'No. Audits and sprints are project-based. Advisory work is usually monthly with a clear review point.',
      },
      {
        title: 'Are ad budgets or software costs included?',
        description:
          'No. Pricing covers consulting time and deliverables. Media spend, software, design, development, and copy production are scoped separately if needed.',
      },
      {
        title: 'Can you work with our internal team?',
        description:
          'Yes. Most engagements are built to support internal marketers, founders, sales leaders, or agency partners.',
      },
      {
        title: 'What if we only need a website review?',
        description:
          'The audit package is usually the right fit. It can focus specifically on conversion, messaging, and service page clarity.',
      },
    ]}
  />

  <CallToAction
    title="Want a recommendation before choosing?"
    subtitle="Send the current growth problem and I will suggest the most sensible starting point."
    actions={[
      {
        variant: 'primary',
        text: 'Ask about fit',
        href: '/contact',
      },
    ]}
  />
</Layout>
