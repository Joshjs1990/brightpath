---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Contact',
};
---

<Layout metadata={metadata}>
  <HeroText tagline="Contact" title="Tell me what you are trying to fix" />

  <ContactUs
    id="form"
    title="Start with a short strategy call"
    subtitle="Share your current growth challenge, what you have tried, and what would make the next quarter feel more focused."
    inputs={[
      {
        type: 'text',
        name: 'name',
        label: 'Name',
      },
      {
        type: 'email',
        name: 'email',
        label: 'Work email',
      },
      {
        type: 'text',
        name: 'company',
        label: 'Company',
      },
    ]}
    textarea={{
      label: 'What would you like help with?',
    }}
    button={{ text: 'Request a call' }}
    disclaimer={{
      label:
        'By submitting this form, you agree to be contacted about your inquiry. Your details will not be sold or shared for unrelated marketing.',
    }}
    description="Most inquiries receive a response within two business days."
  />

  <Features2
    title="Good things to include"
    items={[
      {
        title: 'Current priority',
        description: 'Positioning, website conversion, content, campaigns, reporting, or general growth strategy.',
      },
      {
        title: 'Business context',
        description: 'Who you serve, what you sell, average deal size, sales cycle, and current team setup.',
      },
      {
        title: 'What has changed',
        description: 'A stalled pipeline, new offer, rebrand, launch, new market, or a team that needs clearer direction.',
      },
      {
        title: 'Email',
        description: 'hello@brightpath-marketing.com',
        icon: 'tabler:mail',
      },
      {
        title: 'Location',
        description: 'Available for remote engagements across the US and Europe.',
        icon: 'tabler:map-pin',
      },
      {
        title: 'Availability',
        description: 'Strategy sprints and advisory retainers are booked in limited monthly slots.',
        icon: 'tabler:calendar-time',
      },
    ]}
  />
</Layout>
